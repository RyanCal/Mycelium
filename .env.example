# Runtime environment: development, test, or production.
ENVIRONMENT=development

# Structured log level emitted by kernel and workers.
LOG_LEVEL=INFO

# Async SQLAlchemy URL for Postgres with pgvector.
DATABASE_URL=postgresql+asyncpg://mycelium:mycelium@db:5432/mycelium

# Redis is used for Arq and Pub/Sub.
REDIS_URL=redis://redis:6379/0

# Arq queue used by the scheduler and workers.
ARQ_QUEUE_NAME=mycelium:arq

# API bind settings for the embedded FastAPI server.
API_HOST=0.0.0.0
API_PORT=8000

# Single-user dashboard/API bearer token. Change before exposing anywhere.
MYCELIUM_ADMIN_TOKEN=change-me

# Anthropic is the default LLM provider.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_PROMPT_CACHE=true

# Voyage embeddings are the default cold-memory provider.
VOYAGE_API_KEY=
EMBEDDINGS_PROVIDER=voyage
EMBEDDINGS_MODEL=voyage-3-large
EMBED_DIM=1024

# Docker sandbox defaults. Network none is deliberate until a task needs egress.
SANDBOX_BASE_IMAGE=mycelium/sandbox-base:dev
SANDBOX_NETWORK_MODE=none
SANDBOX_CPU_QUOTA=50000
SANDBOX_MEM_LIMIT=512m
AGENT_VOLUME_ROOT=/var/lib/mycelium/agents

# UI server-side proxy target.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
MYCELIUM_API_BASE_URL=http://kernel:8000
